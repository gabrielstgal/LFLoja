# Banco de Dados
DB_URL=jdbc:postgresql://localhost:5432/lfclothing
DB_USERNAME=postgres
DB_PASSWORD=sua_senha_aqui

# JWT (gere uma chave forte com: openssl rand -hex 32)
JWT_SECRET=sua_chave_secreta_aqui

# Cloudinary
CLOUDINARY_CLOUD_NAME=seu_cloud_name
CLOUDINARY_API_KEY=sua_api_key
CLOUDINARY_API_SECRET=seu_api_secret

# WhatsApp
LOJA_WHATSAPP=5500000000000

# AbacatePay (gateway de pagamento PIX)
# Pegue a chave no painel: https://www.abacatepay.com (use abc_dev_... em desenvolvimento)
ABACATEPAY_API_KEY=abc_dev_sua_chave_aqui
# Segredo definido ao cadastrar o webhook no painel AbacatePay
ABACATEPAY_WEBHOOK_SECRET=seu_segredo_de_webhook_aqui
